generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  loginHistories LoginHistory[]
  cartSnapshots CartSnapshot[]
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  batchNumber String?
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceType String
  productName String?
  quantity    Int
  unitPrice   Float?
  subtotal    Float
  gst         Float
  total       Float
  status      OrderStatus @default(PENDING)
  notes       String?
  labelLayout String?
  fileName    String?
  filePath    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  ipAddress String?
  userAgent String?
  loggedAt  DateTime @default(now())
}

model CartSnapshot {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemsJson String
  itemCount Int
  total     Float
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  AWAITING_FILE
  PROOF_SENT
  APPROVED
  IN_PRINTING
  READY
  SHIPPED
  DELIVERED
  CANCELLED
}
